class Player:
    def __init__(self):
        self.width = SPRITE_WIDTH
        self.height = SPRITE_HEIGHT
        
        self.x = 0
        
        self.y = WINDOW_HEIGHT - self.height
        #velocity v (start)
        self.vel_y = 0
        self.rotation = 0
        
    def jump(self):
        self.vel_y -= 50
        
    def update(self):
        self.vel_y += GRAVITY
               
        self.y += self.vel_y
        
        #falls Player boden beruhrt
        # window = 800
        #y = 805
        #wieder originalhöhe
        if self.y > (WINDOW_HEIGHT - self.height):
            self.y = WINDOW_HEIGHT - self.height
            self.vel_y = 0
            #Player soll nicht mehr rotioeren
            self.rotation = 0
            #Player ist im weiter im Luft
        else:
           self.rotation += 90
    #Funktion draw()
    def draw(self):
        print(self.rotation)
        rotated = pygame.transform.rotate(sprite_img,self.rotation)
        rect = rotated.get_rect(center=(self.x+35,self.y+35))
        screen.blit(sprite_img,rect.topleft)
    def get_rect(self):
        return pygame.Rect(self.x,self.y,SPRITE_WIDTH,SPRITE_HEIGHT)
