import pygame
import random

# Konstanten
WINDOW_WIDTH = 1200
WINDOW_HEIGHT = 600
SPRITE_WIDTH = 70
SPRITE_HEIGHT = 70
SPIKE_HEIGHT = 70
SPIKE_WIDTH = 70
GRAVETY = 0.9
SPEED = 7 # Etwas schneller für mehr Spielspaß

pygame.init()
clock = pygame.time.Clock()

# Screen Setup
wn = pygame.display.set_mode((WINDOW_WIDTH, WINDOW_HEIGHT))
pygame.display.set_caption("Geometry Dash")

# Bilder laden und skalieren
sprite_img = pygame.image.load("sprite.jpg")
sprite_img = pygame.transform.scale(sprite_img, (SPRITE_WIDTH, SPRITE_HEIGHT))

spike1_img = pygame.image.load("spike_1.jpg")
spike2_img = pygame.image.load("spike_2.jpg")
spike3_img = pygame.image.load("spike_3.jpg")

spike1_img = pygame.transform.scale(spike1_img, (SPIKE_WIDTH, SPIKE_HEIGHT))
spike2_img = pygame.transform.scale(spike2_img, (SPIKE_WIDTH, SPIKE_HEIGHT))
spike3_img = pygame.transform.scale(spike3_img, (SPIKE_WIDTH, SPIKE_HEIGHT))
spike_imgs = [spike1_img, spike2_img, spike3_img]

# Klasse Player
class Player:
    def __init__(self):
        self.width = SPRITE_WIDTH
        self.height = SPRITE_HEIGHT
        self.x = 100
        self.y = WINDOW_HEIGHT - self.height
        self.vel_y = 0
        self.rotation = 0
    
    def jump(self):
        # Nur springen, wenn Du den Boden berührst
        if self.y >= WINDOW_HEIGHT - self.height:
            self.vel_y = -18 
        
    def update(self):
        self.vel_y += GRAVETY
        self.y += self.vel_y
        
        # Boden-Kollision
        if self.y > (WINDOW_HEIGHT - self.height):
            self.y = WINDOW_HEIGHT - self.height
            self.vel_y = 0
            self.rotation = 0
        elif self.y < (WINDOW_HEIGHT - self.height):    
            # Rotation nur in der Luft
            self.rotation -= 7 
            
    def draw(self):
        rotated_img = pygame.transform.rotate(sprite_img, self.rotation)
        # Rect zentrieren, damit die Rotation nicht eiert
        rect = rotated_img.get_rect(center=(self.x + self.width // 2, self.y + self.height // 2))
        wn.blit(rotated_img, rect.topleft)
        
    def get_rect(self):
        return pygame.Rect(self.x, self.y, self.width, self.height)
    
# Klasse Spike
class Spike:
    def __init__(self):
        self.width = SPIKE_WIDTH
        self.height = SPIKE_HEIGHT
        self.x = WINDOW_WIDTH
        self.y = WINDOW_HEIGHT - self.height
        self.vel_x = SPEED
        self.img = random.choice(spike_imgs)
        
    def update(self):
        # Bewege Spike nach links auf den Player zu
        self.x -= self.vel_x
        
        # Reset, wenn der Spike links verschwindet
        if self.x < -self.width:
            self.x = WINDOW_WIDTH
            self.img = random.choice(spike_imgs)
        
    def get_rect(self):
        return pygame.Rect(self.x, self.y, self.width, self.height)
    
    def draw(self):
        wn.blit(self.img, (self.x, self.y))

# Instanzen einmalig vor der Schleife erstellen
player = Player()
spike = Spike()

running = True
while running:
    clock.tick(60)
    
    # Events abfragen
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_SPACE or event.key == pygame.K_UP:
                player.jump()

    # Logik aktualisieren
    player.update()
    spike.update()
    
    # Kollision prüfen
    if player.get_rect().colliderect(spike.get_rect()):
        print("Game Over!")
        running = False

    # Zeichnen
    wn.fill((255, 255, 255)) 
    player.draw()
    spike.draw()
    
    pygame.display.flip()
            
pygame.quit()
